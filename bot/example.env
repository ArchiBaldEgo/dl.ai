# --- логин бота (это и есть «данные» для входа в DeepSeek) ---
BOT_USERNAME=email
BOT_PASSWORD=пароль
SERVICE_MODEL=deepseek

# --- прокси ---
BOT_PROXY=
BOT_PROXY_USER=
BOT_PROXY_PASS=

# --- диагностика 401: дамп html+скриншот в bot/worker/logs/ ---
AUTH_DEBUG=1
AUTH_TIMEOUT_MS=45000

# --- API/пул ботов (можно не трогать, дефолты норм) ---
PORT=3000
MAX_BOT_COUNT=3
RETRY_AFTER_SEC=45
REQUEST_TIMEOUT_MS=180000

# --- окно браузера (опционально) ---
VIEWPORT_W=800
VIEWPORT_H=800