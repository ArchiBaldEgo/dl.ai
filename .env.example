SECRET_KEY=change-me
DEBUG=1
CSRF_COOKIE_NAME=csrftoken
SESSION_COOKIE_NAME=ai_sessionid
CSRF_COOKIE_PATH=/ai/
SESSION_COOKIE_PATH=/ai/
CSRF_COOKIE_HTTPONLY=0
CSRF_USE_SESSIONS=0
# Для совместного входа между dl.gsu.by и dlai.gsu.by при необходимости укажите домен:
# CSRF_COOKIE_DOMAIN=.gsu.by
# SESSION_COOKIE_DOMAIN=.gsu.by

# Для Docker: db
# Для локального запуска без Docker: 127.0.0.1
DB_HOST=db
DB_PORT=5432
DB_NAME=dl_ai
DB_USER=dlaibd
DB_PASSWORD=dlaibd

# Локальный Docker nginx bind
AI_NGINX_BIND=0.0.0.0
AI_NGINX_PORT=8080

# Прокси (оставьте пустыми, если прокси не нужен)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,db,nginx,.local
PROXY=

# Прокси для контейнера в рантайме (не подхватывает прокси хоста)
RUNTIME_HTTP_PROXY=
RUNTIME_HTTPS_PROXY=
RUNTIME_NO_PROXY=localhost,127.0.0.1,db,nginx,.local

# Управление прокси для Puppeteer
# PUPPETEER_NO_PROXY=1        # игнорировать любые прокси
# PUPPETEER_PROXY_SERVER=     # пример: http://proxy.gsu.by:800
# PUPPETEER_PROXY_USERNAME=
# PUPPETEER_PROXY_PASSWORD=

# Bot pool (internal API)
BOT_POOL_URL=http://localhost:3000

#API-эндпоинт dl.gsu.by для валидации сессии 
EXTERNAL_AUTH_API_URL=https://dl.gsu.by/restapi/get-user-info

#Cookie c ID сесси на dl.gsu.by
EXTERNAL_SESSION_COOKIE_NAME=DLSID

#Пути, которые мы не проверяем в middleware
EXTERNAL_AUTH_SKIP_PATHS=/health/,/ai/assets/

# Redis cache. Обязательно для production (много Daphne/Gunicorn workers).
# Внутри Docker Compose используйте имя сервиса: redis://redis:6379/1
# Для локальной разработки без Docker: redis://127.0.0.1:6379/1
# Если не задано, Django fallback на LocMemCache (только dev/один процесс).
REDIS_URL=redis://redis:6379/1
REDIS_VOLUME_NAME=dlai_redis_data

# Токены (опционально)
CLIENT_ID=
SBER_SECRET=
HF_TOKEN=
SC_TOKEN=
MIST_TOKEN=
GROQ_TOKEN=
DEEPSEEK_API_TOKEN=
