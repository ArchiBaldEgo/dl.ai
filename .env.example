SECRET_KEY=change-me
DEBUG=1

# Для Docker: db
# Для локального запуска без Docker: 127.0.0.1
DB_HOST=db
DB_PORT=5432
DB_NAME=dl_ai
DB_USER=dlaibd
DB_PASSWORD=dlaibd

ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:8080,http://localhost:8080
USE_X_FORWARDED_PROTO=0
AI_DISABLE_HEALTH_SCHEDULER=0

# Локальный Docker nginx bind
AI_NGINX_BIND=0.0.0.0
AI_NGINX_PORT=8080

# Прокси (оставьте пустыми, если прокси не нужен)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,db,nginx,.local
PROXY=

# Токены (опционально)
CLIENT_ID=
SBER_SECRET=
HF_TOKEN=
SC_TOKEN=
SAMBANOVA_API_KEY=
MIST_TOKEN=
GROQ_TOKEN=
DEEPSEEK_API_TOKEN=
DEEPSEEK_API_KEY=
